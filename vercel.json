{
  "builds": [
    { "src": "api/roadmap.js", "use": "@vercel/node" },
    { "src": "**/*.html", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/roadmap", "dest": "/api/roadmap.js" },
    { "src": "/suggest", "dest": "/leland-builder-2/suggest.html" },
    { "src": "/ai-builder-plan.html", "dest": "/leland-builder-2/ai-builder-plan.html" },
    { "src": "/ai-builder-dashboard.html", "dest": "/leland-builder-2/ai-builder-dashboard.html" },
    { "src": "/time-audit.html", "dest": "/leland-builder-2/time-audit.html" },
    { "src": "/", "dest": "/index.html" },
    { "src": "/(.*)", "dest": "/$1" }
  ]
}
