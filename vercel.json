{
  "builds": [
    { "src": "api/roadmap.js", "use": "@vercel/node" },
    { "src": "*.html", "use": "@vercel/static" },
    { "src": "index.html", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/roadmap", "dest": "/api/roadmap.js" },
    { "src": "/suggest", "dest": "/suggest.html" },
    { "src": "/", "dest": "/ai-builder-dashboard.html" },
    { "src": "/(.*)", "dest": "/$1" }
  ]
}
